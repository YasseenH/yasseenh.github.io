---
import BaseLayout from "../layouts/BaseLayout.astro";
import Reveal from "../components/motion/Reveal.tsx";
import ProofPoints from "../components/ProofPoints.tsx";
import FloatingPhoto from "../components/FloatingPhoto.tsx";

const proofPoints = [
  { label: "Now:", text: "Software Engineering Intern, Visa Inc." },
];
---

<BaseLayout
  title="Yasseen Hilal – Software Engineer"
  description="Yasseen Hilal is a software engineer interning at Visa, with prior internships at Paycom and re:3D. CS student at UT Austin, Class of 2027."
  personSchema
>
  <section class="flex min-h-[calc(100vh-72px)] flex-col justify-center px-6 py-24">
    <div class="mx-auto flex w-full max-w-[1150px] flex-col-reverse gap-16 lg:flex-row lg:items-center lg:justify-between">
      <div class="w-full lg:flex-1">
        <Reveal client:load>
          <p class="mb-6 text-[20px] font-medium leading-[1.4] text-whiteout/70">
            UT Austin Computer Science, Class of 2027
          </p>
        </Reveal>

        <Reveal client:load delay={0.1}>
          <h1 class="font-control-compressed text-[clamp(2.75rem,8.5vw,110px)] font-black uppercase leading-[0.85] text-whiteout">
            Yasseen Hilal
          </h1>
        </Reveal>

        <Reveal client:load delay={0.2}>
          <p class="mt-10 max-w-[700px] text-[16px] leading-[1.5] text-whiteout/80">
            I'm a SWE interning at Visa, after internships at Paycom and re:3D.
            I'm finishing my CS degree at UT, looking ahead to new grad roles in software engineering.
          </p>
        </Reveal>

        <ProofPoints points={proofPoints} client:load />

        <Reveal client:load delay={0.6}>
          <a
            href="/experience"
            class="mt-10 inline-block border-b-2 border-signal-blue px-2 pb-1 text-[16px] font-medium text-signal-blue no-underline transition-opacity hover:opacity-80"
          >
            See the full story &rarr; Experience
          </a>
        </Reveal>
      </div>

      <FloatingPhoto client:load src="/images/yasseen.webp" alt="Yasseen Hilal" width={700} height={875} />
    </div>
  </section>
</BaseLayout>
