---
interface Props {
  name: string;
  stack: string;
  year?: string;
  links?: string[];
  bullets: string[];
}

const { name, stack, year, links, bullets } = Astro.props;
---

<article class="rounded-cards bg-haze p-5 text-ink">
  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
    <h3 class="text-[20px] font-medium leading-[1.4]">{name}</h3>
    {year && <p class="text-[13px] leading-[1.5] text-ink/60">{year}</p>}
  </div>

  <p class="mt-2 text-[13px] leading-[1.5] text-ink/60">{stack}</p>

  {links && links.length > 0 && (
    <div class="mt-3 flex flex-wrap gap-2">
      {links.map((link) => (
        <span class="rounded-pills bg-ink/[0.06] px-3 py-1 text-[13px] font-medium text-ink/70">
          {link}
        </span>
      ))}
    </div>
  )}

  <ul class="mt-4 flex flex-col gap-2">
    {bullets.map((bullet) => (
      <li class="flex gap-3 text-[16px] leading-[1.5] text-ink/80">
        <span class="mt-[9px] h-1 w-1 shrink-0 rounded-full bg-ink/40" />
        <span>{bullet}</span>
      </li>
    ))}
  </ul>
</article>
