---
interface Props {
  company: string;
  role: string;
  location: string;
  dates: string;
  bullets?: string[];
  note?: string;
}

const { company, role, location, dates, bullets, note } = Astro.props;
---

<article class="rounded-cards bg-haze p-5 text-ink">
  <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
    <h3 class="text-[20px] font-medium leading-[1.4]">
      {company} &mdash; {role}
    </h3>
    <p class="text-[13px] leading-[1.5] text-ink/60">{dates}</p>
  </div>
  <p class="mt-1 text-[13px] leading-[1.5] text-ink/60">{location}</p>

  {note && <p class="mt-4 text-[16px] leading-[1.5] text-ink/80">{note}</p>}

  {bullets && bullets.length > 0 && (
    <ul class="mt-4 flex flex-col gap-2">
      {bullets.map((bullet) => (
        <li class="flex gap-3 text-[16px] leading-[1.5] text-ink/80">
          <span class="mt-[9px] h-1 w-1 shrink-0 rounded-full bg-ink/40" />
          <span>{bullet}</span>
        </li>
      ))}
    </ul>
  )}
</article>
